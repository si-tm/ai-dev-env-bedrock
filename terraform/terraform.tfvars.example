# ============================================================
# terraform/terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# Usage: cp terraform.tfvars.example terraform.tfvars
# ============================================================

aws_region           = "ap-northeast-1"
project_name         = "ai-dev-env"
instance_type        = "t3.medium"   # t3.large recommended for heavy use
root_volume_size     = 30

# IMPORTANT: restrict to your IP address (e.g. "203.0.113.10/32")
allowed_cidr_blocks  = ["YOUR_IP/32"]

# Path to your SSH public key
public_key_path      = "~/.ssh/id_rsa.pub"

# Password for code-server browser UI
code_server_password = "CHANGE_ME_strong_password"

common_tags = {
  Project     = "ai-dev-env"
  ManagedBy   = "terraform"
  Environment = "dev"
}
