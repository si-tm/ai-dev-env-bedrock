# ============================================================
# .gitignore — ai-dev-env-bedrock
# ============================================================

# ── CloudFormation ───────────────────────────────────────────
cfn/parameters.json        # 実際のパラメータ（シークレット含む）
!cfn/parameters.json.example

# ── Terraform (旧構成・念のため残す) ─────────────────────────
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!terraform.tfvars.example

# ── Docker / Environment ──────────────────────────────────────
docker/.env
.env
.env.*
!.env.example

# ── SSH Keys ─────────────────────────────────────────────────
*.pem
*.key
id_rsa
id_ed25519

# ── AWS Credentials ──────────────────────────────────────────
.aws/
credentials

# ── nginx certs ──────────────────────────────────────────────
docker/nginx/certs/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
