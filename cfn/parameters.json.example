# ============================================================
# cfn/parameters.json
# CloudFormation パラメータファイル（aws cloudformation deployで使用）
# Usage: cp parameters.json.example parameters.json && 編集
# ============================================================
[
  {
    "ParameterKey": "ProjectName",
    "ParameterValue": "ai-dev-env"
  },
  {
    "ParameterKey": "InstanceType",
    "ParameterValue": "t3.medium"
  },
  {
    "ParameterKey": "RootVolumeSize",
    "ParameterValue": "30"
  },
  {
    "ParameterKey": "VpcCidr",
    "ParameterValue": "10.0.0.0/16"
  },
  {
    "ParameterKey": "SubnetCidr",
    "ParameterValue": "10.0.1.0/24"
  },
  {
    "ParameterKey": "AllowedCidr",
    "ParameterValue": "YOUR_IP/32"
  },
  {
    "ParameterKey": "KeyPairName",
    "ParameterValue": ""
  },
  {
    "ParameterKey": "CodeServerPassword",
    "ParameterValue": "CHANGE_ME_strong_password"
  },
  {
    "ParameterKey": "AwsRegion",
    "ParameterValue": "ap-northeast-1"
  }
]
